# Public DNS name of the server.
DOMAIN=bot.example.com

# Email for Let's Encrypt registration and renewal notifications.
CERTBOT_EMAIL=ops@example.com

# Application runtime
BOT_VSTRECHI_DB_PATH=/data/local.db
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=

# Optional calendar integration
BOT_VSTRECHI_CALENDAR_ENABLED=false
BOT_VSTRECHI_RECURRING_EXCEPTIONS_ONLY_ENABLED=false
BOT_VSTRECHI_RUN_BACKGROUND_WORKERS=false
GOOGLE_SA_CLIENT_EMAIL=
GOOGLE_SA_PRIVATE_KEY=
GOOGLE_SA_PRIVATE_KEY_ID=
GOOGLE_SA_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_IMPERSONATION_SUBJECT=
GOOGLE_WEBHOOK_CHANNEL_TOKEN=

# Logging and runtime tuning
LOG_LEVEL=INFO
LOG_FORMAT=json
BOT_VSTRECHI_BACKGROUND_WORKER_TICK_SECONDS=0.5
BOT_VSTRECHI_CALENDAR_POLL_INTERVAL_SECONDS=60
BOT_VSTRECHI_RETENTION_CLEANUP_INTERVAL_SECONDS=1800
BOT_VSTRECHI_RETENTION_CHECKPOINT_INTERVAL_SECONDS=21600
BOT_VSTRECHI_RETENTION_VACUUM_INTERVAL_SECONDS=604800
BOT_VSTRECHI_RETENTION_CALENDAR_SYNC_SIGNAL_DAYS=5
BOT_VSTRECHI_RETENTION_OUTBOX_DAYS=14
BOT_VSTRECHI_RETENTION_JOB_DAYS=14
BOT_VSTRECHI_RETENTION_AUDIT_LOG_DAYS=30
BOT_VSTRECHI_RETENTION_INBOUND_EVENT_DAYS=7
