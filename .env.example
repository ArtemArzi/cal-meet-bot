# Copy to .env.local and adjust values.

# App/runtime
BOT_VSTRECHI_DB_PATH=./var/local.db
# Optional. If empty, webhook secret check is disabled.
TELEGRAM_SECRET_TOKEN=
TELEGRAM_BOT_TOKEN=dev-token

# Optional integrations
BOT_VSTRECHI_CALENDAR_ENABLED=false
BOT_VSTRECHI_RECURRING_EXCEPTIONS_ONLY_ENABLED=false
BOT_VSTRECHI_RUN_BACKGROUND_WORKERS=true
GOOGLE_SA_CLIENT_EMAIL=
GOOGLE_SA_PRIVATE_KEY=
GOOGLE_SA_PRIVATE_KEY_ID=
GOOGLE_SA_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_IMPERSONATION_SUBJECT=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=pretty

# Uvicorn
HOST=0.0.0.0
PORT=8000
RELOAD=1
